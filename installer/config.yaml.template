# Kira config — RTX 5080 / 16 GB VRAM profile.
# Generated by the installer on first install. Edit freely; subsequent
# updates will NOT overwrite this file.

audio:
  # Software gain multiplier applied to raw mic samples before VAD/Whisper.
  # Tweak between 1 and 200 depending on your microphone.
  # Generic USB-Audio-Class hardware often needs 50-100;
  # ROG/Nahimic/Sonic Studio with hardware boost usually 1-10 (mic_boost
  # in the driver already amplifies; further software gain just clips).
  #
  # AFTER FIRST F8: check %LOCALAPPDATA%\Kira\kira.log for the
  # "Recorder.stop: peak=... rms=..." line.
  #   peak >= 0.95  → audio is clipping, drop input_gain by 5x and retry
  #   rms  <  0.01  → too quiet, raise by 5x and retry
  #   peak 0.3-0.9, rms 0.05-0.15 → sweet spot
  # If Whisper still hallucinates "Vielen Dank." despite good levels,
  # see input_device below.
  input_gain: 5.0

  # Pin sounddevice to a specific input device. null = let Windows pick
  # the default — works on most setups. BUT: if Kira keeps transcribing
  # "Vielen Dank." or "Untertitelung des ZDF" no matter what you say,
  # your default device is routing through a noise-cancellation layer
  # (typical with ASUS AI Noise-Canceling, NVIDIA Broadcast, Krisp, etc.)
  # that filters speech as noise. Symptom: scripts/audio_diagnose.py
  # raw test shows rms <0.001 even when speaking.
  #
  # Fix: set this to a substring of your physical mic's device name
  # (case-insensitive). Run scripts/audio_diagnose.py to enumerate.
  # Examples:
  #   input_device: "ROG Theta"           # ROG Theta Ultimate headset
  #   input_device: "Headset Microphone"  # generic gaming headset
  #   input_device: "Realtek"             # onboard mic
  input_device: null

whisper:
  # Local path to the bundled CTranslate2 build of Systran/faster-whisper-large-v3.
  # The installer placed the model files at this exact path.
  model: C:/Users/${USERNAME}/models/faster-whisper-large-v3
  language: de
  # 0.15 lässt fast alles durch — PTT-Modus (F8 hold) macht VAD redundant,
  # höhere Werte filterten kurze Aufnahmen komplett (siehe 2026-04-25 debug).
  vad_threshold: 0.15
  condition_on_previous_text: false
  initial_prompt: "Kira, Whisper, Ollama, GitHub, Python, Linux, Windows."

styler:
  # Polish-step LLM. gemma3:12b is the sweet spot for 16 GB VRAM:
  #   ~7 GB VRAM + ~3 GB whisper = ~10 GB used, ~6 GB headroom.
  # Latency on a 5080-class GPU: under 1 s for a 50-word polish AFTER warmup.
  #
  # If your GPU has less VRAM, drop to:
  #   model: gemma3:4b   # ~3 GB VRAM, marginally lower polish quality
  model: gemma3:12b
  # Cold-Start für 12B ~6-8s, für 27B ~14s. Großzügig dimensioniert damit
  # der allererste Polish-Call durchläuft. Nach Warmup spielt der Wert keine
  # Rolle mehr — Polish dauert <1s. Symptom bei zu kurzem Wert: Log zeigt
  # "Styler timed out after Xs" und alle Polish-Versuche fallen auf Raw zurück.
  timeout_seconds: 30.0
  fallback_to_raw: true
